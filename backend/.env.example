# ── Server identity (used ONLY when fetching external RSS feeds) ──────────────
SERVER_SOURCE_NAME=GNews-RSS-Bot/1.0

# ── Server config ─────────────────────────────────────────────────────────────
PORT=5001

# ── Database & Vercel ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://...
CRON_SECRET=...

# ── CORS: comma-separated allowed frontend origins ───────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Expected X-Client-Source value from frontend ─────────────────────────────
EXPECTED_CLIENT_SOURCE=GNews-Web

# ── Feed refresh interval in minutes (Used for local only) ───────────────────
FEED_REFRESH_MINUTES=15

# ── Admin credentials (hardcoded — change before deploying) ──────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@GNews123

# ── JWT secret (use a long random string in production) ──────────────────────
JWT_SECRET=gnews-super-secret-jwt-key-change-in-prod
JWT_EXPIRES_IN=24h
